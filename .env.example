# Copy to .env.local and fill in. NEVER commit real values.
# See SPEC.md → Architecture → "Env vars".

# Anthropic Messages API key (server-side only).
ANTHROPIC_API_KEY=

# SociaVault API key (primary Instagram resolver — post-info endpoint).
SOCIAVAULT_API_KEY=

# Instagram scraper API key (Apify Instagram Post Scraper — fallback resolver).
SCRAPER_API_KEY=

# Instagram driver order (comma-separated). Default: sociavault,apify
# RESOLVE_DRIVER_ORDER=sociavault,apify

# Google Maps Platform key (Places API — Text Search) for location enrichment.
# Optional: if unset, enrichment is a no-op. Restrict this key to the Places API.
GOOGLE_MAPS_API_KEY=
