# Copy to .env.local and fill in. NEVER commit real values.
# See SPEC.md → Architecture → "Env vars".

# Anthropic Messages API key (server-side only).
ANTHROPIC_API_KEY=

# Instagram scraper API key (Apify Instagram Post Scraper or equivalent).
SCRAPER_API_KEY=

# Google Maps Platform key (Places API — Text Search) for location enrichment.
# Optional: if unset, enrichment is a no-op. Restrict this key to the Places API.
GOOGLE_MAPS_API_KEY=
